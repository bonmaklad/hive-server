{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "note_body", "dev_plan_markdown", "next_stage", "files_touched", "test_commands"],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "note_body": {
      "type": "string",
      "minLength": 1
    },
    "dev_plan_markdown": {
      "type": "string",
      "minLength": 1
    },
    "next_stage": {
      "type": "string",
      "const": "qa-tester"
    },
    "files_touched": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "test_commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
