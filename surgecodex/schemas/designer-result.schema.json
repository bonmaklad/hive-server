{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "note_body", "design_markdown", "next_stage", "design_principles", "ui_ux_checks"],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "note_body": {
      "type": "string",
      "minLength": 1
    },
    "design_markdown": {
      "type": "string",
      "minLength": 1
    },
    "next_stage": {
      "type": "string",
      "const": "analyst"
    },
    "design_principles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "ui_ux_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
